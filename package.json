{
  "name": "openclaw-office",
  "version": "0.1.0",
  "description": "Virtual AI Office Dashboard for OpenClaw — visualize your multi-agent workflows in real-time",
  "license": "MIT",
  "type": "module",
  "bin": {
    "openclaw-office": "./cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/as84089443/openclaw-office.git"
  },
  "scripts": {
    "dev": "next dev -p 4200",
    "build": "next build",
    "discord-reports:sync": "node ../scripts/sync-discord-report-prompts.mjs",
    "migrate:fnb": "node scripts/fnb-migrate.mjs",
    "start": "node start.js",
    "demo": "node scripts/run-fnb-demo.mjs",
    "boss-inbox:digest": "node scripts/deliver-boss-inbox-digest.mjs",
    "evolution:promote": "node scripts/run-memory-distiller-promoter.mjs",
    "merchant-line:prepare-env": "node scripts/superfish-prepare-env.mjs",
    "merchant-line:rich-menu": "node scripts/superfish-rich-menu.mjs --write-env",
    "merchant-line:liff": "node scripts/superfish-create-liff.mjs",
    "merchant-line:sync-rich-menu": "node scripts/superfish-sync-rich-menu.mjs",
    "merchant-line:webhook": "node scripts/superfish-configure-line-webhook.mjs",
    "office:open": "sh scripts/open-office-ui.sh",
    "office:open:local": "sh scripts/open-office-ui.sh --local",
    "office:open:public": "sh scripts/open-office-ui.sh --public",
    "copilot:install-service": "zsh scripts/install-openclaw-copilot-launchd.sh",
    "copilot:uninstall-service": "zsh scripts/uninstall-openclaw-copilot-launchd.sh",
    "selfhost:deploy": "sh scripts/selfhost-zero-touch-deploy.sh",
    "selfhost:deploy:host": "sh scripts/selfhost-zero-touch-deploy.sh --mode host --public-url https://copilot.bw-space.com --install-docker",
    "selfhost:deploy:nas": "sh scripts/selfhost-zero-touch-deploy.sh --mode nas --skip-public",
    "selfhost:deploy:host:quiet": "sh scripts/selfhost-zero-touch-deploy.sh --mode host --public-url https://copilot.bw-space.com --install-docker --quiet",
    "selfhost:deploy:nas:quiet": "sh scripts/selfhost-zero-touch-deploy.sh --mode nas --skip-public --quiet",
    "selfhost:deploy:sync": "sh scripts/selfhost-zero-touch-pipeline.sh",
    "selfhost:deploy:sync:git": "sh scripts/selfhost-zero-touch-pipeline.sh --git-sync",
    "selfhost:deploy:sync:quiet": "sh scripts/selfhost-zero-touch-pipeline.sh --quiet",
    "superfish:prepare-env": "node scripts/superfish-prepare-env.mjs",
    "superfish:rich-menu": "node scripts/superfish-rich-menu.mjs --write-env",
    "superfish:liff": "node scripts/superfish-create-liff.mjs",
    "superfish:live-check": "node scripts/superfish-live-check.mjs",
    "superfish:go-live": "npm run superfish:live-check && npm run superfish:webhook && npm run superfish:sync-rich-menu && npm run superfish:live-check",
    "superfish:sync-rich-menu": "node scripts/superfish-sync-rich-menu.mjs",
    "superfish:webhook": "node scripts/superfish-configure-line-webhook.mjs",
    "fnb:merchant-copilot:worker": "node scripts/fnb-merchant-copilot-worker.mjs",
    "fnb:merchant-copilot:worker:once": "node scripts/fnb-merchant-copilot-worker.mjs --once",
    "test:discord-reports": "node --test tests/discord-report-prompts.test.mjs tests/fish-input-snapshot.test.mjs && node ../scripts/validate-discord-report-prompts.mjs",
    "test:fnb": "node --test tests/fnb-service.test.mjs",
    "test:boss-inbox": "node --test tests/boss-inbox.test.mjs",
    "test:office-auth": "node --test tests/office-auth.test.mjs",
    "test:evolution": "node --test tests/evolution-loop.test.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1"
  },
  "dependencies": {
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "framer-motion": "^12.4.7",
    "inquirer": "^13.2.2",
    "lucide-react": "^0.474.0",
    "next": "^15.5.12",
    "ora": "^9.3.0",
    "pg": "^8.16.3",
    "pg-mem": "^3.0.5",
    "postcss": "^8.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "ws": "^8.19.0"
  }
}
