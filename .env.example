# OpenClaw Office Environment Variables
# Copy to .env.local and fill in your values
#
# ALL variables are OPTIONAL — the dashboard works without any of them.
# Only fill in what you need.

# ── Gateway Connection (optional — overrides config file) ──
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ── Office Customization ──
OFFICE_NAME=My AI Office
OFFICE_STYLE=cyberpunk

# ── Image Generation (optional — for generating custom office scenes) ──
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# ── Position Detection (optional — Claude Vision for desk positions) ──
# ANTHROPIC_API_KEY=

# ── Telegram Notifications (optional) ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_WEBHOOK_SECRET=
