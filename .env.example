# OpenClaw Office Environment Variables
# Copy to .env.local and fill in your values
#
# ALL variables are OPTIONAL — the dashboard works without any of them.
# Only fill in what you need.

# ── Gateway Connection (optional — overrides config file) ──
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ── Office Customization ──
OFFICE_NAME=My AI Office
OFFICE_STYLE=cyberpunk

# ── Image Generation (optional — for generating custom office scenes) ──
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# ── Position Detection (optional — Claude Vision for desk positions) ──
# ANTHROPIC_API_KEY=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# F&B Copilot runtime
FNB_APP_ENV=demo
FNB_DEMO_MODE=1
FNB_PUBLIC_BASE_URL=http://localhost:4200
FNB_INTERNAL_API_TOKEN=
FNB_SQLITE_PATH=
DATABASE_URL=
DATABASE_SSL=0

# Merchant LINE OA / LIFF
# Keep these separate from any other product-level LINE credentials such as SuperFish.
FNB_LINE_BRAND_NAME=BW-Copilot Merchant
LINE_CHANNEL_ID=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
NEXT_PUBLIC_LINE_LIFF_ID=
# Legacy fallback names (optional)
FNB_LINE_CHANNEL_ID=
FNB_LINE_CHANNEL_ACCESS_TOKEN=
FNB_LINE_CHANNEL_SECRET=
FNB_LINE_LOGIN_CHANNEL_ID=
FNB_LINE_LOGIN_CHANNEL_SECRET=
NEXT_PUBLIC_FNB_LINE_LIFF_ID=
LINE_RICH_MENU_IMAGE_BASE64=
FNB_LINE_RICH_MENU_IMAGE_BASE64_PATH=data/fnb-merchant/merchant-rich-menu.base64.txt
FNB_LINE_RICH_MENU_IMAGE_BASE64=

# Google OAuth / Business Profile
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
